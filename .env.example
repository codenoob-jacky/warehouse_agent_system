# 金蝶系统
KINGDEE_BASE_URL=http://your-kingdee-server:8080
KINGDEE_USERNAME=your-username
KINGDEE_PASSWORD=your-password
KINGDEE_DATABASE=your-database

# OCR
OCR_USE_GPU=False

# 文件上传
UPLOAD_FOLDER=./uploads